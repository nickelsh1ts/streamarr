{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':dependencyDashboard',
    ':timezone(America/Toronto)',

    'group:nextjsMonorepo',
    'group:reactMonorepo',
    'group:typescript-eslintMonorepo',
    'group:tailwindcssMonorepo',

    'github>nickelsh1ts/streamarr//.github/renovate/actions.json5',
    'github>nickelsh1ts/streamarr//.github/renovate/docker.json5',
    'github>nickelsh1ts/streamarr//.github/renovate/groups.json5',
    'github>nickelsh1ts/streamarr//.github/renovate/labels.json5',
    'github>nickelsh1ts/streamarr//.github/renovate/pnpm.json5',
    'github>nickelsh1ts/streamarr//.github/renovate/semanticCommits.json5',
  ],

  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: ['prEditedNotification', 'prIgnoreNotification'],

  labels: ['dependencies'],
  schedule: ['before 6am on monday'],
  prConcurrentLimit: 10,
  prHourlyLimit: 2,

  minimumReleaseAge: '7 days',
  rebaseWhen: 'conflicted',
  platformAutomerge: true,

  vulnerabilityAlerts: {
    labels: ['security'],
    automerge: true,
  },

  customManagers: [
    {
      customType: 'regex',
      description: 'Track Node workflow containers',
      fileMatch: ['^\\.github/workflows/.+\\.ya?ml$'],
      matchStrings: ['container:\\s*node:(?<currentValue>\\d+(?:\\.\\d+){0,2})(?:-[^@\\s]+)?(?:@sha256:[a-fA-F0-9]+)?'],
      datasourceTemplate: 'node',
      depNameTemplate: 'node',
      versioningTemplate: 'node',
    },
    {
      customType: 'regex',
      description: 'Track actions/setup-node runtime',
      fileMatch: ['^\\.github/workflows/.+\\.ya?ml$'],
      matchStrings: ['node-version:\\s*[\"\']?(?<currentValue>\\d+(?:\\.\\d+(?:\\.\\d+)?)?)[\"\']?'],
      datasourceTemplate: 'node',
      depNameTemplate: 'node',
      versioningTemplate: 'node',
    },
    {
      customType: 'regex',
      description: 'Track package engines.node lower bound major',
      fileMatch: ['^package\\.json$'],
      matchStrings: ['\"node\"\\s*:\\s*\">=(?<currentValue>\\d+)\\.0\\.0\"'],
      datasourceTemplate: 'node',
      depNameTemplate: 'node',
      versioningTemplate: 'node',
    },
  ],

  packageRules: [
    // Auto-merge non-major devDependency updates without review
    {
      matchDepTypes: ['devDependencies'],
      matchUpdateTypes: ['minor', 'patch'],
      automerge: true,
    },
  ],
}
