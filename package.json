{
  "name": "streamarr",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "nodemon -e ts --watch server --watch streamarr-api.yml -e .json,.ts,.yml -x tsx --tsconfig server/tsconfig.json server/index.ts",
    "build:next": "next build",
    "build:server": "tsc --project server/tsconfig.json && copyfiles -u 2 server/templates/**/*.{html,pug} dist/templates && tsc-alias -p server/tsconfig.json",
    "build": "pnpm build:next && pnpm build:server",
    "prepare": "pnpm format && pnpm lint && pnpm css-lint && pnpm typecheck",
    "lint": "eslint \"./server/**/*.{ts,tsx}\" \"./src/**/*.{ts,tsx}\" --cache",
    "start": "NODE_ENV=production node dist/index.js",
    "css-lint": "stylelint src/styles/*.css public/*.css",
    "i18n:extract": "formatjs extract 'src/**/*.{ts,tsx}' --ignore='src/**/*.d.ts' --out-file src/i18n/locale/en.json --id-interpolation-pattern '[sha512:contenthash:base64:6]'",
    "migration:generate": "tsx --tsconfig server/tsconfig.json ./node_modules/typeorm/cli.js migration:generate -d server/datasource.ts",
    "migration:create": "tsx --tsconfig server/tsconfig.json ./node_modules/typeorm/cli.js migration:create",
    "migration:run": "tsx --tsconfig server/tsconfig.json ./node_modules/typeorm/cli.js migration:run -d server/datasource.ts",
    "format": "prettier 'src/**/*.{css,js,ts,tsx}' 'server/**/*.{css,js,ts,tsx}' --log-level warn --write --cache .",
    "format:check": "prettier 'src/**/*.{css,js,ts,tsx}' 'server/**/*.{css,js,ts,tsx}' --check --cache .",
    "typecheck": "pnpm typecheck:server && pnpm typecheck:client",
    "typecheck:server": "tsc --project server/tsconfig.json --noEmit",
    "typecheck:client": "tsc --noEmit",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:prepare": "tsx --tsconfig server/tsconfig.json server/scripts/prepareTestDb.ts",
    "cypress:build": "pnpm build && pnpm cypress:prepare",
    "css-build": "tailwindcss -o public/tailwind.css",
    "css-watch": "tailwindcss -o public/tailwind.css --watch",
    "start:python": "cd server/python && CONFIG_DIRECTORY=../../config gunicorn -w 2 -b 0.0.0.0:5005 --timeout 60 --graceful-timeout 30 --keep-alive 5 plex_invite:app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nickelsh1ts/streamarr.git"
  },
  "license": "MIT",
  "dependencies": {
    "@ctrl/deluge": "^8.0.0",
    "@ctrl/qbittorrent": "^9.11.2",
    "@ctrl/shared-torrent": "^6.5.1",
    "@ctrl/transmission": "^7.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@dr.pogodin/csurf": "^1.16.9",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "axios": "^1.15.0",
    "axios-rate-limit": "^1.9.0",
    "bcrypt": "^6.0.0",
    "bowser": "^2.14.1",
    "colord": "^2.9.3",
    "connect-typeorm": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cronstrue": "^3.14.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "email-templates": "^13.0.1",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "formik": "^2.4.9",
    "http-proxy-middleware": "^3.0.5",
    "ical": "^0.8.0",
    "isomorphic-dompurify": "^3.8.0",
    "jose": "^6.2.2",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.47",
    "multer": "^2.1.1",
    "next": "^16.2.3",
    "nextjs-toploader": "^3.9.17",
    "node-cache": "^5.1.2",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.5",
    "ofetch": "^1.5.1",
    "openpgp": "^6.3.0",
    "plex-api": "5.3.2",
    "prop-types": "^15.8.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-animate-height": "^3.2.3",
    "react-aria": "^3.48.0",
    "react-big-calendar": "^1.19.4",
    "react-colorful": "^5.6.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-intl": "^10.1.2",
    "react-markdown": "^10.1.0",
    "react-popper-tooltip": "^4.4.2",
    "react-select": "^5.10.2",
    "react-spring": "^10.0.3",
    "react-use-clipboard": "1.0.9",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "secure-random-password": "^0.2.3",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "swr": "^2.4.1",
    "theme-change": "^2.5.0",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^2.0.9",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xml2js": "^0.6.2",
    "yamljs": "^0.3.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@formatjs/cli": "^6.14.2",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/cookie-parser": "^1.4.10",
    "@types/copyfiles": "^2.4.4",
    "@types/email-templates": "^10.0.4",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.1",
    "@types/ical": "^0.8.3",
    "@types/lodash": "^4.17.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/node-schedule": "^2.1.8",
    "@types/prop-types": "^15.7.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "4.4.12",
    "@types/secure-random-password": "^0.2.3",
    "@types/semver": "^7.7.1",
    "@types/web-push": "^3.6.4",
    "@types/xml2js": "^0.4.14",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "autoprefixer": "^10.5.0",
    "commitizen": "4.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "copyfiles": "^2.4.1",
    "cy-mobile-commands": "^0.3.0",
    "cypress": "^15.13.1",
    "cz-conventional-changelog": "3.3.0",
    "daisyui": "4.12.24",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-formatjs": "^6.4.5",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.5.0",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "postcss": "8.5.9",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "sass": "^1.99.0",
    "semantic-release": "^25.0.3",
    "stylelint": "^17.7.0",
    "tailwindcss": "3.4.19",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": "^22.0.0",
    "pnpm": "^10.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx,js}": [
      "prettier --write",
      "eslint"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits",
          "presetConfig": {
            "types": [
              {
                "type": "feat",
                "section": "✨ Features"
              },
              {
                "type": "fix",
                "section": "🐛 Bug Fixes"
              },
              {
                "type": "perf",
                "section": "⚡ Performance"
              },
              {
                "type": "revert",
                "section": "⏪ Reverts"
              },
              {
                "type": "docs",
                "section": "📚 Documentation"
              },
              {
                "type": "style",
                "section": "💎 Styles"
              },
              {
                "type": "refactor",
                "section": "♻️ Refactoring"
              },
              {
                "type": "test",
                "section": "🧪 Tests"
              },
              {
                "type": "build",
                "section": "📦 Build System"
              },
              {
                "type": "ci",
                "section": "🤖 CI/CD"
              },
              {
                "type": "chore",
                "section": "🔧 Chores",
                "hidden": true
              }
            ]
          }
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "addReleases": "bottom"
        }
      ]
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "cypress",
      "sharp",
      "sqlite3"
    ],
    "overrides": {
      "eslint-config-next>typescript-eslint": "^8.58.2"
    }
  }
}
